{
  "baseUrl": "{{if(connection.baseUrl, connection.baseUrl, 'https://loopquest.tomphillips.uk')}}",
  "headers": {
    "authorization": "Bearer {{connection.apiKey}}"
  },
  "response": {
    "error": "[{{statusCode}}] {{body.error}}"
  },
  "log": {
    "sanitize": ["request.headers.authorization"]
  }
}
